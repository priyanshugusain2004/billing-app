PORT=5000
NODE_ENV=development

# Database
# Local:
# MONGO_URI=mongodb://localhost:27017/billing-app
# Atlas:
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/billing-app

# JWT
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRY=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Subscription settings
SUBSCRIPTION_ONBOARDING_FEE_INR=500
SUBSCRIPTION_VALIDITY_DAYS=30

# Owner analytics access (required for /api/analytics/*)
PLATFORM_ADMIN_KEY=replace_with_owner_only_secret_key
